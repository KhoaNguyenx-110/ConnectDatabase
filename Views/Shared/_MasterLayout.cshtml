<!DOCTYPE html>

<html>
<head>
    <a href="~/lib/bootstrap/dist/css/bootstrap.min.css.map"></a>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
        @RenderSection("MyStyle",false)
</head>
<body>
    <div class="Header">@RenderSection("sec_header")</div>
    <div>
        @RenderBody()
    </div>
    <div class="Footer"> @RenderSection("sec_footer")</div>
    <nav class="navbar navbar-expand bg-light border-bottom shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold" href="#">
                Supplier
            </a>

            <div class="navbar-nav">
                <a asp-controller="Supplier"
                   asp-action="Index"
                   class="nav-link">
                    Index
                </a>

                <a asp-controller="Supplier"
                   asp-action="About"
                   class="nav-link">
                    About
                </a>
            </div>

        </div>
    </nav>
    <div>@RenderSection("image")</div>
</body>
</html>
