@using ConnectDatabase.Models
@model IEnumerable<Product>
@{
    decimal average = Model?.Average(p => p.Price) ?? 0;
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<h4 class="bg-primary text-white text-center m-2 p-2">
    Product List
</h4>
<table class="table table-striped table bordered">
    <tr>
        <th>Name</th>
        <th>Price</th>
        @* <th>Average</th> *@
    </tr>
    @foreach(Product product in Model?? Enumerable.Empty<Product>())
    {
      @*   <tr>
            <td>@product.Name</td>
            <td>@product.Price</td>
            <td>@((product.Price/average*100).ToString("F1"))% of average</td>
        </tr> *@
        <partial name="_RowPartial" model="product" />
        <td colspan="2">
            @((product.Price/average * 100).ToString("F1")) %  average
        </td>
    }
</table>
<div class="d-flex gap-2">
    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-primary">
        Home
    </a>

    <a asp-controller="Cubed"
       asp-action="Index"
       class="btn btn-success">
        Cube
    </a>
</div>