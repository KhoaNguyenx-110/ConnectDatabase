@page "{id:long}"
@model ConnectDatabase.Pages.EditModel
@{
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<h2>Edit Supplier</h2>
<form method="post" class="form-control">
    <table>
        <tr>
            <th>
                ID
            </th>
            <td>
                <input asp-for="supplier.SupplierId" readonly />
            </td>
        </tr>
        <tr>
            <th>
                Name
            </th>
            <td>
                <input asp-for="supplier.Name" class="form-control" />
            </td>
        </tr>
        <tr>
            <th>
                City
            </th>
            <td>
                <input asp-for="supplier.City" class="form-control" />
            </td>
        </tr>
        <tr>
            <td colspan="2"><button typeof="submit" class="btn btn-success">Save</button></td>
        </tr>
    </table>
</form>
